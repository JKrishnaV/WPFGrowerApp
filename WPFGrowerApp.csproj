<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net6.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <EnableDefaultPageItems>false</EnableDefaultPageItems>
  </PropertyGroup>

  <ItemGroup>
    <Resource Include="Images\*.svg" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="AspNetCore.Reporting" Version="2.1.0" />
    <PackageReference Include="Microsoft.SqlServer.Types" Version="14.0.1016.290" />
    <PackageReference Include="System.Data.SqlClient" Version="4.8.5" />
    <PackageReference Include="System.Text.Encoding.CodePages" Version="7.0.0" />
    <PackageReference Include="SharpVectors" Version="1.8.2" />
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.0.2210.55" />
  </ItemGroup>

  <ItemGroup>
    <Reference Include="System.Windows.Forms" />
    <Reference Include="WindowsFormsIntegration" />
    <Reference Include="Microsoft.mshtml">
      <HintPath>$(MSBuildProgramFiles32)\Microsoft.NET\Primary Interop Assemblies\Microsoft.mshtml.dll</HintPath>
      <EmbedInteropTypes>true</EmbedInteropTypes>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Reports\*.rdlc">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </EmbeddedResource>
  </ItemGroup>

  <!-- Explicitly include all source files -->
  <ItemGroup>
    <Compile Include="**\*.cs" Exclude="obj\**\*.cs" />
    <Page Include="**\*.xaml" Exclude="obj\**\*.xaml" />
    <Compile Update="**\*.xaml.cs" DependentUpon="%(Filename)" />
    <Page Update="**\*.xaml" SubType="Designer" Generator="MSBuild:Compile" />
  </ItemGroup>

  <!-- Include Reports folder files -->
  <ItemGroup>
    <Compile Include="Reports\ReportViewerWindow.xaml.cs" DependentUpon="ReportViewerWindow.xaml" />
    <Page Include="Reports\ReportViewerWindow.xaml" SubType="Designer" Generator="MSBuild:Compile" />
  </ItemGroup>

  <!-- Exclude any duplicates from Views -->
  <ItemGroup>
    <Compile Remove="Views\EmailDialog.xaml.cs" />
    <Page Remove="Views\EmailDialog.xaml" />
    <Compile Remove="Views\ReportViewerWindow.xaml.cs" />
    <Page Remove="Views\ReportViewerWindow.xaml" />
  </ItemGroup>

</Project>
